#!/usr/bin/env node

/**
 * generate-pdf-from-html.mjs — HTML/text → PDF
 *
 * Two modes:
 *   1. Spec mode (preferred): Builds cover letter PDF via @json-render/react-pdf
 *   2. HTML mode (legacy): Reads HTML file, renders via Playwright
 *
 * Usage:
 *   # Spec mode — cover letter with resume-matching design
 *   node generate-pdf-from-html.mjs <output.pdf> --body="Cover letter text..." [--company "Acme Corp"]
 *
 *   # Spec mode from file
 *   node generate-pdf-from-html.mjs <output.pdf> --body-file=<path> [--company "Acme Corp"]
 *
 *   # HTML mode (Playwright)
 *   node generate-pdf-from-html.mjs <input.html> <output.pdf> [--format=a4|letter]
 */

import { chromium } from 'playwright';
import { resolve, dirname } from 'path';
import { readFile, mkdir } from 'fs/promises';
import { existsSync } from 'fs';
import { fileURLToPath } from 'url';
import { renderToFile } from '@json-render/react-pdf';
import { buildCoverLetterSpec } from './lib/cover-letter-spec.mjs';

const __dirname = dirname(fileURLToPath(import.meta.url));

async function renderViaPlaywright(inputPath, outputPath, format) {
  let html = await readFile(inputPath, 'utf-8');

  const browser = await chromium.launch({
    headless: true,
    args: ['--font-render-hinting=none'],
  });

  try {
    const page = await browser.newPage({
      viewport: { width: 794, height: 1123 },
      deviceScaleFactor: 2,
    });

    await page.setContent(html, {
      waitUntil: 'networkidle',
      baseURL: `file://${dirname(inputPath)}/`,
    });

    await page.evaluate(() => document.fonts.ready);
    await page.waitForTimeout(500);

    const outputDir = dirname(outputPath);
    await mkdir(outputDir, { recursive: true });

    await page.pdf({
      path: outputPath,
      format: format,
      printBackground: true,
      margin: { top: '0.2in', right: '0.2in', bottom: '0.2in', left: '0.2in' },
    });

    const { statSync } = await import('fs');
    const stats = statSync(outputPath);
    console.log(`✅ PDF: ${outputPath} (${(stats.size / 1024).toFixed(1)} KB)`);
  } finally {
    await browser.close();
  }
}

async function renderViaSpec(body, outputPath, opts) {
  const { spec, registry } = buildCoverLetterSpec({
    body,
    date: opts.date,
    company: opts.company,
  });

  await mkdir(dirname(outputPath), { recursive: true });
  await renderToFile(spec, outputPath, { registry });

  const { statSync } = await import('fs');
  const stats = statSync(outputPath);
  console.log(`✅ PDF: ${outputPath} (${(stats.size / 1024).toFixed(1)} KB)`);
}

async function main() {
  const args = process.argv.slice(2);
  let inputPath = null;
  let outputPath = null;
  let format = 'a4';
  let body = null;
  let bodyFile = null;
  let date = null;
  let company = null;

  // Detect mode: spec mode if any --body* flag present
  const isSpecMode = args.some(a => a.startsWith('--body'));

  // Collect positional args (non-flag)
  const positional = [];

  for (const arg of args) {
    if (arg === '--format' || arg === '--body-file' || arg === '--date' || arg === '--company') continue;
    if (arg.startsWith('--format=')) { format = arg.split('=')[1]; continue; }
    if (arg.startsWith('--body-file=')) { bodyFile = arg.split('=')[1]; continue; }
    if (arg.startsWith('--date=')) { date = arg.split('=')[1]; continue; }
    if (arg.startsWith('--company=')) { company = arg.split('=')[1]; continue; }
    if (arg.startsWith('--body=')) { body = arg.split('=')[1]; continue; }
    if (arg.startsWith('--')) continue;
    positional.push(arg);
  }

  if (isSpecMode) {
    // Spec mode: output.pdf [--body=...] [--body-file=...]
    outputPath = positional[0] ? resolve(positional[0]) : null;
  } else {
    // HTML mode: input.html output.pdf
    inputPath = positional[0] ? resolve(positional[0]) : null;
    outputPath = positional[1] ? resolve(positional[1]) : null;
  }

  // Handle --body-file (read file after args parsed)
  if (!body && bodyFile) {
    body = await readFile(resolve(bodyFile), 'utf-8');
  }

  // Spec mode
  if (isSpecMode) {
    if (!outputPath || !body) {
      console.error(`Usage: node generate-pdf-from-html.mjs <output.pdf> --body="text..." [--company "Acme Corp"]`);
      console.error(`   or: node generate-pdf-from-html.mjs <output.pdf> --body-file=<path> [--company "Acme Corp"]`);
      process.exit(1);
    }

    await renderViaSpec(body, outputPath, { date, company });
    process.stdout.write(outputPath + '\n');
    return;
  }

  // HTML mode
  if (!inputPath || !outputPath) {
    console.error('Usage (HTML mode): node generate-pdf-from-html.mjs <input.html> <output.pdf> [--format=a4|letter]');
    console.error('Usage (spec mode):   node generate-pdf-from-html.mjs <output.pdf> --body="text..." [--company "Acme Corp"]');
    process.exit(1);
  }

  if (!existsSync(inputPath)) {
    console.error('Input not found:', inputPath);
    process.exit(1);
  }

  await renderViaPlaywright(inputPath, outputPath, format);
  process.stdout.write(outputPath + '\n');
}

main().catch(err => {
  console.error('❌', err.message);
  process.exit(1);
});
